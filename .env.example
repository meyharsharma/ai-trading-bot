# --- Kraken (read-only) ---
# Generated at https://www.kraken.com/u/security/api with QUERY-only permissions.
# This is what gets submitted to organizers for leaderboard verification.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Path to the Kraken CLI binary (Rust). Used as the MCP server entrypoint.
KRAKEN_CLI_PATH=kraken

# --- LLM ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# --- ERC-8004 / On-chain ---
# Use the chain ERC-8004 is deployed on (Base Sepolia is the likely default).
RPC_URL=
CHAIN_ID=84532
# Burner key for the agent. NEVER reuse a personal wallet.
AGENT_PRIVATE_KEY=
ERC8004_REGISTRY_ADDRESS=
HACKATHON_VAULT_ADDRESS=

# --- PRISM (Strykr) ---
# Redeem with code LABLAB for $10 credits.
PRISM_API_KEY=

# --- Ops ---
# Optional: Telegram alerts on errors.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
